---
import ContactForm from "../components/ContactForm.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { siteData } from "../data/site";

const page = siteData.contact;
const site = siteData.site;
---

<MainLayout title={page.title} description={page.description}>
  <section class="page-hero">
    <div class="container contact-grid">
      <div class="contact-rail">
        <div>
          <p class="eyebrow">{page.eyebrow}</p>
          <h1>{page.heading}</h1>
          <p class="page-copy">{page.intro}</p>
        </div>

        <div class="contact-note">
          <p><strong>{page.labels.email}:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
          <p><strong>{page.labels.phone}:</strong> <a href={`tel:${site.phone.replace(/[^+\d]/g, "")}`}>{site.phone}</a></p>
          <p><strong>{page.labels.mobile}:</strong> <a href={`tel:${site.mobile.replace(/[^+\d]/g, "")}`}>{site.mobile}</a></p>
          <p><strong>{page.labels.address}:</strong> {site.address}</p>
        </div>
      </div>

      <ContactForm />
    </div>
  </section>
</MainLayout>
