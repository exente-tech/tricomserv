---
import MainLayout from "../layouts/MainLayout.astro";
import { siteData } from "../data/site";

const home = siteData.home;
---

<MainLayout title={home.title} description={home.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{home.eyebrow}</p>
        <h1>{home.headline}</h1>
        <p class="hero-copy">{home.intro}</p>
        <p class="trust-line">{home.trustLine}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/contact">{home.primaryCta}</a>
          <a class="button button-secondary" href="/sisteme-de-pompare">{home.secondaryCta}</a>
        </div>
      </div>

      <div class="hero-aside">
        <article class="hero-visual">
          <span class="hero-visual-kicker">Tricomserv Pompe</span>
          <h2>{home.heroVisualTitle}</h2>
          <p>{home.heroVisualBody}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="positioning-block">
        <p class="section-label">Poziționare</p>
        <h2>{home.positioningTitle}</h2>
        <p class="section-copy">{home.positioningBody}</p>
      </div>
    </div>
  </section>

  <section class="section section-tight-top">
    <div class="container">
      <div class="section-heading">
        <p class="section-label">Servicii</p>
        <h2>Serviciile noastre</h2>
      </div>

      <div class="card-grid two">
        {home.quickLinks.map((item) => (
          <a class="card" href={item.href}>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <span class="card-link">{item.linkLabel}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-band">
    <div class="container split-grid">
      <div>
        <p class="section-label">Aplicații</p>
        <h2>{home.sectorsTitle}</h2>
      </div>

      <div class="applications-grid">
        {home.sectors.map((item) => (
          <article class="mini-card">
            <span class="mini-card-icon" aria-hidden="true"></span>
            <strong>{item}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="section-label">Avantaje</p>
        <h2>{home.whyTitle}</h2>
      </div>

      <div class="value-grid">
        {home.whyItems.map((item) => (
          <article class="mini-card mini-card-advantage">
            <strong>{item}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section cta-banner-section">
    <div class="container">
      <div class="cta-banner">
        <div>
          <h2>{home.ctaTitle}</h2>
          <p class="cta-copy">{home.ctaBody}</p>
        </div>
        <a class="button button-primary" href="/contact">{home.ctaButton}</a>
      </div>
    </div>
  </section>
</MainLayout>
